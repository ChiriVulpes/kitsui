{
  "name": "kitsui",
  "version": "0.1.0",
  "description": "UI framework template built around mutable Component wrappers and explicit State transitions.",
  "main": "./dist/kitsui.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/kitsui.umd.js"
    }
  },
  "unpkg": "dist/kitsui.umd.js",
  "jsdelivr": "dist/kitsui.umd.js",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "build:docs": "tsx ./scripts/docs.ts",
    "watch": "tsx ./scripts/watch.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260405.1",
    "esbuild": "0.27.3",
    "happy-dom": "20.8.3",
    "vitest": "4.1.2",
    "typedoc": "0.28.18",
    "tsx": "4.21.0",
    "markdown-it": "14.1.1",
    "@types/markdown-it": "14.1.2",
    "@vitest/utils": "4.1.2",
    "chokidar": "5.0.0",
    "ws": "8.20.0",
    "dotenv": "17.3.1",
    "typedoc-plugin-missing-exports": "4.1.3",
    "monaco-editor": "0.55.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}