{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "agent: test",
      "type": "process",
      "command": "pnpm",
      "args": ["test:run"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
	  "presentation": {
		"showReuseMessage": false
	  }
    },
    {
      "label": "agent: typecheck",
      "type": "process",
      "command": "pnpm",
      "args": ["typecheck"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
	  "presentation": {
		"showReuseMessage": false
	  }
    },
    {
      "label": "agent: verify",
      "dependsOrder": "parallel",
      "dependsOn": ["agent: typecheck", "agent: test"],
      "problemMatcher": []
    }
  ]
}